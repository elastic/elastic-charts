{
  "name": "@elastic/charts",
  "description": "Elastic-Charts data visualization library",
  "version": "71.6.0",
  "author": "Elastic DataVis",
  "license": "SEE LICENSE IN LICENSE.txt",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "repository": "git@github.com:elastic/elastic-charts.git",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    },
    "./dist/theme_light.css": "./dist/theme_light.css",
    "./dist/theme_dark.css": "./dist/theme_dark.css",
    "./dist/theme_only_light.css": "./dist/theme_only_light.css",
    "./dist/theme_only_dark.css": "./dist/theme_only_dark.css",
    "./dist/legacy/*": "./dist/legacy/*",
    "./dist/theme.scss": "./dist/theme.scss"
  },
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "scripts": {
    "api:check": "yarn build:dts && yarn api:extract",
    "api:check:local": "yarn build:dts && yarn api:extract --local",
    "api:extract": "yarn api-extractor run -c ./api-extractor.jsonc --verbose",
    "build": "yarn build:clean && rslib build && yarn build:collect:css && yarn concat:sass",
    "build:dts": "yarn build:clean && yarn tsc -p ./tsconfig.src.json --emitDeclarationOnly --declaration --declarationMap --outDir ./dist/types",
    "build:pack": "yarn build && npm pack",
    "build:clean": "echo 'Cleaning dist...' && rm -rf ./dist",
    "build:collect:css": "mkdir -p ./dist/legacy && cp ./dist/esm/*.css ./dist/ && cp ./dist/esm/legacy/*.css ./dist/legacy/",
    "build:watch": "echo 'Watching build...' && yarn build:clean && rslib build --watch",
    "concat:sass": "echo 'Concat SASS...' && node scripts/concat_sass.js",
    "semantic-release": "semantic-release",
    "typecheck": "tsc -p ./tsconfig.src.json --noEmit"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@reduxjs/toolkit": "1.9.7",
    "bezier-easing": "^2.1.0",
    "chroma-js": "^2.4.2",
    "classnames": "^2.2.6",
    "d3-array": "^1.2.4",
    "d3-cloud": "^1.2.5",
    "d3-collection": "^1.0.7",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^3.3.0",
    "d3-shape": "^2.0.0",
    "immer": "^9.0.21",
    "prop-types": "^15.7.2",
    "re-reselect": "^4.0.1",
    "react-redux": "^8.1.3",
    "redux": "^4.2.1",
    "ts-debounce": "^4.0.0",
    "utility-types": "^3.10.0",
    "uuid": "^9",
    "luxon": "^1.25.0"
  },
  "peerDependencies": {
    "moment": "^2.29.1",
    "moment-timezone": "^0.5.32",
    "react": "^16.12 || ^17.0 || ^18.0",
    "react-dom": "^16.12 || ^17.0 || ^18.0"
  },
  "devDependencies": {
    "@rslib/core": "^0.21.5",
    "@rsbuild/plugin-react": "^2.0.0",
    "@rsbuild/plugin-sass": "^1.5.2",
    "@types/react": "^18",
    "@types/react-dom": "^18"
  },
  "browserslist": [
    "last 2 versions",
    "ie 11"
  ]
}
